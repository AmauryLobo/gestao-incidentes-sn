        <script><![CDATA[(function executeRule(current, previous) {
    // Status inicial
    current.status = '1'; // substitui pelo value de Aberto
    
    // Copia o número gerado automaticamente
    current.numero = current.getValue('number');
    
    // Calcula prioridade
    var impacto = current.impacto.toString();
    var urgencia = current.urgencia.toString();

    if (impacto == '1' && urgencia == '1') {
        current.prioridade = '1';
    } else if ((impacto == '1' && urgencia == '2') || (impacto == '2' && urgencia == '1')) {
        current.prioridade = '2';
    } else if ((impacto == '1' && urgencia == '3') || (impacto == '2' && urgencia == '2') || (impacto == '3' && urgencia == '1')) {
        current.prioridade = '3';
    } else {
        current.prioridade = '4';
    }
})(current, previous);]]></script>
